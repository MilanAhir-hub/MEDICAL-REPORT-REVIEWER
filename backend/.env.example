# ── Server Config ─────────────────────────────────────────────────────────────
# Port to run the server on (default: 5000)
PORT=5000

# Node Environment: production or development
NODE_ENV=development

# ── Databases ─────────────────────────────────────────────────────────────────
# MongoDB connection URI (Atlas or local instance)
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/medical-report-reviewer?retryWrites=true&w=majority

# ── Authentication ────────────────────────────────────────────────────────────
# Secret key to sign JSON Web Tokens
JWT_SECRET=your_jwt_secret_key_here_make_it_long_and_random

# Google OAuth 2.0 Credentials (for login with Google)
GOOGLE_CLIENT_ID=your_google_client_id_here.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
# In development: http://localhost:5000/api/auth/google/callback
# In production: https://your-api-domain.com/api/auth/google/callback
GOOGLE_REDIRECT_URI=http://localhost:5000/api/auth/google/callback

# ── Cloudinary Configuration ──────────────────────────────────────────────────
# Credentials for report attachment storage
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name_here
CLOUDINARY_API_KEY=your_cloudinary_api_key_here
CLOUDINARY_API_SECRET=your_cloudinary_api_secret_here

# ── Google Gemini AI ─────────────────────────────────────────────────────────
# Gemini API Key for OCR normalization & clinical report analysis
GEMINI_API_KEY=AIzaSyYourGeminiApiKeyHere

# ── Client Config ─────────────────────────────────────────────────────────────
# Origin URL allowed to access backend endpoints (CORS whitelist)
# In development: http://localhost:5173
# In production: https://your-frontend-domain.com
FRONTEND_URL=http://localhost:5173
